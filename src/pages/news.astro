---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const news = [
  { title: "One Piece: Netflix confirma temporada 2 de Live Action com novos cenários confirmados por Eiichiro Oda", date: "02 Jun 2025", cat: "Live Action", img: "https://cdn.myanimelist.net/images/anime/6/73245l.jpg", desc: "A segunda temporada de One Piece Live Action vai expandir o mundo com cenários nunca antes vistos no anime.", tags: ["Netflix", "One Piece", "Live Action"] },
  { title: "Studio Pierrot anuncia novo anime original de Masashi Kishimoto, autor de Naruto", date: "01 Jun 2025", cat: "Anúncio", img: "https://cdn.myanimelist.net/images/anime/3/41234l.jpg", desc: "Será uma história 100% original do criador de Naruto, sem adaptações de manga.", tags: ["Pierrot", "Kishimoto", "Novo Anime"] },
  { title: "Demon Slayer: Hashira Training quebra recordes de bilheteria mundial com 50 milhões na abertura", date: "31 Mai 2025", cat: "Bilheteria", img: "https://cdn.myanimelist.net/images/anime/6/101186l.jpg", desc: "O filme de Kimetsu no Yaiba se tornou a maior abertura de 2024 no Japão e está causando furor global.", tags: ["Demon Slayer", "Bilheteria", "Filme"] },
  { title: "Crunchyroll expande para 10 novos mercados asiáticos com legendas em idiomas locais", date: "30 Mai 2025", cat: "Indústria", img: "https://cdn.myanimelist.net/images/anime/11/75223l.jpg", desc: "A plataforma de streaming mais popular do mundo anuncia expansão massiva na Ásia.", tags: ["Crunchyroll", "Streaming"] },
  { title: "Studio Ghibli confirma novo filme para 2026 dirigido por Hayao Miyazaki", date: "28 Mai 2025", cat: "Notícia", img: "https://cdn.myanimelist.net/images/anime/6/74077l.jpg", desc: "O lendário estúdio japonês confirma projeto que está em desenvolvimento há anos.", tags: ["Ghibli", "Miyazaki", "Filme"] },
  { title: "Spy x Family: data de estreia da 3ª temporada confirmada para outono de 2025", date: "27 Mai 2025", cat: "Lançamento", img: "https://cdn.myanimelist.net/images/anime/8/200441l.jpg", desc: "A família mais querida do anime está de volta com novos casos e aventuras.", tags: ["Spy x Family", "Temporada"] },
];

const categories = ["Todas", "Anúncio", "Lançamento", "Bilheteria", "Indústria", "Live Action"];
---

<Base title="Notícias" description=" últimas notícias do mundo otaku e anime">
  <Header />
  
  <main class="max-w-7xl mx-auto px-4 py-12">

    <!-- Page Header -->
    <div class="text-center mb-12 reveal">
      <h1 class="text-5xl md:text-6xl font-black mb-4">
        <span class="text-neon-cyan neon-glow">Notícias</span> em tempo real
      </h1>
      <p class="text-gray-400 text-lg">Tudo que está acontecendo no universo otaku • Atualizado diariamente</p>
    </div>

    <!-- Category tabs -->
    <div class="flex gap-2 mb-10 overflow-x-auto pb-2 reveal">
      {categories.map((c, i) => (
        <button class={`flex-none px-5 py-2 rounded-full text-sm font-semibold transition-all ${i === 0 ? 'bg-neon-cyan text-gray-950' : 'bg-gray-900 border border-gray-700 text-gray-300 hover:border-neon-cyan hover:text-neon-cyan'}`}>
          {c}
        </button>
      ))}
    </div>

    <!-- Featured big news -->
    <article class="mb-12 reveal group">
      <div class="relative rounded-3xl overflow-hidden bg-gray-900 border border-gray-800 card-hover">
        <div class="grid md:grid-cols-2 gap-0">
          <div class="aspect-video md:aspect-auto overflow-hidden">
            <img src={news[0].img} alt={news[0].title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" loading="lazy" />
          </div>
          <div class="p-8 flex flex-col justify-center">
            <div class="flex items-center gap-3 mb-4">
              <span class="px-3 py-1 text-xs font-bold rounded-full bg-neon-cyan/20 text-neon-cyan">{news[0].cat}</span>
              <span class="text-xs text-gray-500">📅 {news[0].date}</span>
            </div>
            <h2 class="text-2xl md:text-3xl font-black mb-4 leading-tight group-hover:text-neon-cyan transition-colors">{news[0].title}</h2>
            <p class="text-gray-400 mb-6">{news[0].desc}</p>
            <div class="flex gap-2 flex-wrap">
              {news[0].tags.map(t => <span class="px-3 py-1 text-xs rounded-full bg-gray-800 text-gray-400">#{t}</span>)}
            </div>
          </div>
        </div>
      </div>
    </article>

    <!-- News grid -->
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 stagger-children">
      {news.slice(1).map(n => (
        <article class="bg-gray-900 rounded-2xl overflow-hidden border border-gray-800 card-hover shimmer reveal group">
          <div class="aspect-video overflow-hidden relative">
            <img src={n.img} alt={n.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
            <div class="absolute top-3 left-3 px-2 py-1 text-xs font-bold rounded bg-neon-purple/80 text-white backdrop-blur-sm">{n.cat}</div>
          </div>
          <div class="p-5">
            <span class="text-xs text-gray-500 font-mono mb-3 block">📅 {n.date}</span>
            <h3 class="font-bold text-lg mb-3 group-hover:text-neon-cyan transition-colors leading-tight">{n.title}</h3>
            <p class="text-gray-400 text-sm mb-4">{n.desc}</p>
            <div class="flex gap-2 flex-wrap">
              {n.tags.map(t => <span class="text-xs text-gray-500">#{t}</span>)}
            </div>
          </div>
        </article>
      ))}
    </div>

  </main>

  <Footer />
</Base>