---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Footer from '../components/Footer.astro';

// Featured hero post
const heroPost = {
  title: "Frieren: Beyond Journey's End — Por que este é o anime da década",
  cat: "Review Especial", tag: "⭐ 10/10", score: "10",
  img: "https://cdn.myanimelist.net/images/anime/1015/138006l.jpg",
  desc: "Uma jornada emocional que redefine o que um anime pode ser. Frieren não é só sobre magia ou aventura — é sobre o tempo, a perda e o significado الحقيقي de amar alguém.",
  author: "OtakuBlog Team", date: "03 Jun 2025", readTime: "12 min"
};

// Featured grid
const featured = [
  { title: "One Piece finalmente chega ao Egghead Arc", cat: "Notícia", tag: "🔥 Hot", img: "https://cdn.myanimelist.net/images/anime/6/73245l.jpg", desc: "Luffy e crew chegam à ilha científica mais avançada do mundo.", read: "5 min" },
  { title: "Kimetsu no Yaiba: Hashira Training — Review", cat: "Review", tag: "9.5/10", img: "https://cdn.myanimelist.net/images/anime/6/101186l.jpg", desc: "Um arco que eleva a série a novos patamarões de animação e narrativa.", read: "8 min" },
  { title: "Top 10 Animes de todos os tempos - 2025", cat: "Ranking", tag: "📊 Atualizado", img: "https://cdn.myanimelist.net/images/anime/5/11607l.jpg", desc: "Nossa lista definitiva com os melhores animes já feitos.", read: "6 min" },
];

// Category sections
const trendingAnimes = [
  { title: "Demon Slayer: Katana do Tribunal", cat: "Filme", img: "https://cdn.myanimelist.net/images/anime/6/101186l.jpg", rating: "9.5" },
  { title: "Jujutsu Kaisen: Shinjuku Showdown", cat: "Anime", img: "https://cdn.myanimelist.net/images/anime/1/191262l.jpg", rating: "9.2" },
  { title: "Chainsaw Man: Denji's Return", cat: "Anime", img: "https://cdn.myanimelist.net/images/anime/6/194041l.jpg", rating: "8.5" },
  { title: "Spy x Family: Operation Harvest", cat: "Anime", img: "https://cdn.myanimelist.net/images/anime/8/200441l.jpg", rating: "9.0" },
  { title: "Attack on Titan: Final Season", cat: "Anime", img: "https://cdn.myanimelist.net/images/anime/10/47347l.jpg", rating: "9.1" },
];

const recentReviews = [
  { title: "Fullmetal Alchemist: Brotherhood — Análise completa", img: "https://cdn.myanimelist.net/images/anime/5/11607l.jpg", score: "9.6", cat: "Review" },
  { title: "Hunter x Hunter: A obra-prima de Togashi", img: "https://cdn.myanimelist.net/images/anime/6/20057l.jpg", score: "9.7", cat: "Review" },
  { title: "Vinland Saga: História e filosofia", img: "https://cdn.myanimelist.net/images/anime/12/76049l.jpg", score: "9.5", cat: "Review" },
  { title: "Mob Psycho 100: Comédia e profundidade", img: "https://cdn.myanimelist.net/images/anime/9/77809l.jpg", score: "9.0", cat: "Review" },
];

const newsList = [
  { title: "Studio Pierrot anuncia novo anime de Masashi Kishimoto", date: "01 Jun", cat: "Notícia", img: "https://cdn.myanimelist.net/images/anime/3/41234l.jpg" },
  { title: "Demon Slayer quebra recordes de bilheteria mundial", date: "31 Mai", cat: "Notícia", img: "https://cdn.myanimelist.net/images/anime/6/101186l.jpg" },
  { title: "Crunchyroll expande para 10 novos mercados asiáticos", date: "30 Mai", cat: "Indústria", img: "https://cdn.myanimelist.net/images/anime/11/75223l.jpg" },
  { title: "Netflix confirma temporada 2 de One Piece Live Action", date: "29 Mai", cat: "Live Action", img: "https://cdn.myanimelist.net/images/anime/6/73245l.jpg" },
  { title: "Studio Ghibli confirma novo filme para 2026", date: "28 Mai", cat: "Notícia", img: "https://cdn.myanimelist.net/images/anime/6/74077l.jpg" },
];

const tags = ["One Piece", "Frieren", "Demon Slayer", "Jujutsu Kaisen", "Attack on Titan", "Ação", "Drama", "Fantasia", "Comédia", "Shonen", "Seinen", "Isekai"];
---

<Base title="Home">
  <Header />
  <Hero />
  
  <main class="max-w-7xl mx-auto px-4 py-12">

    <!-- ============ HERO POST ============ -->
    <section class="mb-16 reveal">
      <div class="relative group rounded-3xl overflow-hidden bg-gray-900 border border-gray-800 cursor-pointer card-hover">
        <div class="grid md:grid-cols-2 gap-0">
          <div class="aspect-video md:aspect-auto overflow-hidden">
            <img src={heroPost.img} alt={heroPost.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" />
          </div>
          <div class="p-8 md:p-12 flex flex-col justify-center">
            <div class="flex items-center gap-3 mb-4">
              <span class="px-3 py-1 text-xs font-bold rounded-full bg-gradient-to-r from-neon-pink to-neon-purple text-white">{heroPost.cat}</span>
              <span class="px-3 py-1 text-xs font-bold rounded-full bg-neon-cyan/20 text-neon-cyan">{heroPost.tag}</span>
            </div>
            <h2 class="text-2xl md:text-4xl font-black mb-4 leading-tight group-hover:text-neon-pink transition-colors">{heroPost.title}</h2>
            <p class="text-gray-400 mb-6 leading-relaxed">{heroPost.desc}</p>
            <div class="flex items-center justify-between">
              <div class="flex items-center gap-3 text-sm text-gray-500">
                <span>👤 {heroPost.author}</span>
                <span>•</span>
                <span>📅 {heroPost.date}</span>
                <span>•</span>
                <span>⏱️ {heroPost.readTime}</span>
              </div>
              <button class="px-6 py-2 bg-gradient-to-r from-neon-pink to-neon-purple text-white font-bold rounded-full hover:scale-105 transition-transform text-sm">
                Ler artigo →
              </button>
            </div>
          </div>
        </div>
        <!-- Score badge -->
        <div class="absolute top-4 right-4 w-16 h-16 rounded-full bg-neon-cyan flex items-center justify-center text-xl font-black text-gray-950 shadow-lg">
          {heroPost.score}
        </div>
      </div>
    </section>

    <!-- ============ FEATURED GRID ============ -->
    <section class="mb-16">
      <div class="flex items-center justify-between mb-8 reveal">
        <h2 class="text-3xl font-black flex items-center gap-3">
          <span class="w-1 h-8 bg-neon-pink rounded-full"></span>
          Em destaque
        </h2>
        <a href="/reviews" class="text-sm font-semibold text-neon-purple hover:text-neon-pink transition-colors flex items-center gap-1">
          Ver todos →
        </a>
      </div>
      <div class="grid md:grid-cols-3 gap-6 stagger-children">
        {featured.map(post => (
          <article class="group bg-gray-900 rounded-2xl overflow-hidden border border-gray-800 card-hover shimmer reveal">
            <div class="aspect-video overflow-hidden relative">
              <img src={post.img} alt={post.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
              <div class="absolute inset-0 bg-gradient-to-t from-gray-900/80 to-transparent"></div>
              <span class="absolute bottom-3 left-3 px-2 py-1 text-xs font-bold rounded bg-neon-purple/80 text-white backdrop-blur-sm">{post.cat}</span>
            </div>
            <div class="p-5">
              <div class="flex items-center gap-2 mb-3">
                <span class="text-xs font-mono text-neon-cyan">{post.tag}</span>
                <span class="text-xs text-gray-500">• {post.read}</span>
              </div>
              <h3 class="font-bold text-lg mb-2 group-hover:text-neon-pink transition-colors leading-tight">{post.title}</h3>
              <p class="text-gray-400 text-sm">{post.desc}</p>
            </div>
          </article>
        ))}
      </div>
    </section>

    <!-- ============ TRENDING + NEWS SIDEBAR LAYOUT ============ -->
    <section class="mb-16 grid lg:grid-cols-3 gap-8">

      <!-- Trending anime horizontal scroll -->
      <div class="lg:col-span-2 reveal">
        <h2 class="text-3xl font-black mb-8 flex items-center gap-3 reveal">
          <span class="w-1 h-8 bg-neon-cyan rounded-full"></span>
          🔥 Em alta
        </h2>
        <div class="flex gap-4 overflow-x-auto pb-4 snap-x snap-mandatory scrollbar-hide">
          {trendingAnimes.map(a => (
            <div class="flex-none w-48 group cursor-pointer reveal">
              <div class="rounded-2xl overflow-hidden bg-gray-900 border border-gray-800 card-hover">
                <div class="aspect-[3/4] overflow-hidden relative">
                  <img src={a.img} alt={a.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
                  <div class="absolute top-2 right-2 px-2 py-1 text-xs font-black rounded-full bg-neon-cyan text-gray-950">
                    {a.rating}
                  </div>
                  <div class="absolute bottom-0 inset-x-0 h-1/2 bg-gradient-to-t from-gray-900 to-transparent"></div>
                  <span class="absolute bottom-2 left-2 text-xs font-semibold text-gray-300">{a.cat}</span>
                </div>
                <div class="p-3">
                  <h3 class="font-bold text-sm leading-tight group-hover:text-neon-pink transition-colors">{a.title}</h3>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Latest news list -->
      <div class="reveal">
        <h2 class="text-3xl font-black mb-8 flex items-center gap-3 reveal">
          <span class="w-1 h-8 bg-neon-purple rounded-full"></span>
          📰 Últimas notícias
        </h2>
        <div class="space-y-4">
          {newsList.map(n => (
            <article class="flex gap-3 group cursor-pointer reveal">
              <div class="w-20 h-16 rounded-xl overflow-hidden flex-none">
                <img src={n.img} alt={n.title} class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-300" loading="lazy" />
              </div>
              <div class="flex-1 min-w-0">
                <span class="text-xs text-neon-purple font-semibold">{n.cat} • {n.date}</span>
                <h3 class="text-sm font-semibold leading-tight group-hover:text-neon-pink transition-colors mt-1">{n.title}</h3>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- ============ REVIEWS CAROUSEL ============ -->
    <section class="mb-16 reveal">
      <div class="flex items-center justify-between mb-8 reveal">
        <h2 class="text-3xl font-black flex items-center gap-3">
          <span class="w-1 h-8 bg-neon-pink rounded-full"></span>
          ✍️ Últimos Reviews
        </h2>
        <a href="/reviews" class="text-sm font-semibold text-neon-purple hover:text-neon-pink transition-colors">Ver todos →</a>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4 stagger-children">
        {recentReviews.map(r => (
          <article class="group bg-gray-900 rounded-2xl overflow-hidden border border-gray-800 card-hover shimmer reveal">
            <div class="aspect-video overflow-hidden relative">
              <img src={r.img} alt={r.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
              <div class="absolute top-2 right-2 px-3 py-1 rounded-full bg-neon-cyan text-gray-950 font-black text-sm shadow-lg">
                {r.score}
              </div>
              <span class="absolute bottom-2 left-2 px-2 py-1 text-xs font-bold rounded bg-neon-purple/80 text-white backdrop-blur-sm">{r.cat}</span>
            </div>
            <div class="p-4">
              <h3 class="font-semibold text-sm group-hover:text-neon-pink transition-colors leading-tight">{r.title}</h3>
            </div>
          </article>
        ))}
      </div>
    </section>

    <!-- ============ NEWSLETTER ============ -->
    <section class="mb-16 reveal">
      <div class="relative rounded-3xl overflow-hidden bg-gradient-to-r from-neon-purple/20 via-gray-900 to-neon-pink/20 border border-neon-purple/20 p-10 text-center">
        <div class="relative z-10">
          <div class="text-4xl mb-4">📬</div>
          <h2 class="text-3xl font-black mb-3">Fique por dentro!</h2>
          <p class="text-gray-400 mb-8 max-w-lg mx-auto">Receba os melhores reviews, notícias quentes e rankings direto no seu email. Sem spam, só conteúdo de qualidade.</p>
          <form class="flex gap-3 max-w-md mx-auto flex-wrap sm:flex-nowrap" onsubmit="event.preventDefault(); this.querySelector('button').textContent='✓ Enviado!';">
            <input type="email" placeholder="seu@email.com" required class="flex-1 px-5 py-3 rounded-full bg-gray-800 border border-gray-700 text-white placeholder-gray-500 focus:outline-none focus:border-neon-purple transition-colors" />
            <button type="submit" class="px-8 py-3 bg-gradient-to-r from-neon-pink to-neon-purple text-white font-bold rounded-full hover:scale-105 transition-transform whitespace-nowrap">
              Inscrever-se
            </button>
          </form>
        </div>
        <!-- Background decoration -->
        <div class="absolute top-0 right-0 w-40 h-40 bg-neon-pink/10 rounded-full blur-3xl"></div>
        <div class="absolute bottom-0 left-0 w-32 h-32 bg-neon-purple/10 rounded-full blur-3xl"></div>
      </div>
    </section>

    <!-- ============ TAGS CLOUD ============ -->
    <section class="mb-16 reveal">
      <h2 class="text-2xl font-black mb-6 flex items-center gap-3">
        <span class="w-1 h-8 bg-neon-cyan rounded-full"></span>
        🔖 Tags populares
      </h2>
      <div class="flex flex-wrap gap-2">
        {tags.map(tag => (
          <a href="#" class="px-4 py-2 rounded-full bg-gray-900 border border-gray-800 text-sm font-semibold hover:border-neon-pink hover:text-neon-pink transition-colors card-hover">
            #{tag}
          </a>
        ))}
      </div>
    </section>

    <!-- ============ STATS BANNER ============ -->
    <section class="mb-8 reveal">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 p-6 rounded-2xl bg-gradient-to-r from-gray-900 via-gray-900 to-neon-purple/10 border border-gray-800 text-center">
        {[
          { label: "Artigos publicados", value: "128", icon: "📝" },
          { label: "Animes cobertos", value: "500+", icon: "🎬" },
          { label: "Membros ativos", value: "10.000+", icon: "👥" },
          { label: "Avaliações feitas", value: "3.200+", icon: "⭐" },
        ].map(s => (
          <div class="reveal">
            <div class="text-3xl mb-2">{s.icon}</div>
            <div class="text-2xl font-black text-neon-pink neon-glow">{s.value}</div>
            <div class="text-xs text-gray-400 mt-1">{s.label}</div>
          </div>
        ))}
      </div>
    </section>

  </main>

  <Footer />
</Base>