---
const navLinks = [
  { label: "Início", href: "/" },
  { label: "Animes", href: "/reviews", sub: [
    { label: "Reviews", href: "/reviews" },
    { label: "Em alta", href: "/rankings" },
    { label: "Lançamentos", href: "/news" },
  ]},
  { label: "Notícias", href: "/news" },
  { label: "Rankings", href: "/rankings" },
  { label: "Community", href: "#" },
];
---

<header id="site-header" class="border-b border-neon-purple/10 bg-gray-950/80 backdrop-blur-md sticky top-0 z-50 transition-all duration-300">
  <nav class="max-w-7xl mx-auto px-4 py-3 flex items-center justify-between">
    <a href="/" class="flex items-center gap-2 group">
      <span class="text-2xl">🌸</span>
      <span class="text-2xl font-black tracking-tight">
        <span class="text-neon-pink neon-glow">OTAKU</span><span class="text-neon-cyan">BLOG</span>
      </span>
    </a>

    <ul class="hidden md:flex items-center gap-1">
      {navLinks.map(link => (
        <li class="relative group">
          <a href={link.href} class="px-4 py-2 text-sm font-semibold hover:text-neon-pink transition-colors flex items-center gap-1">
            {link.label}
            {link.sub && <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>}
          </a>
          {link.sub && (
            <div class="absolute top-full left-0 hidden group-hover:block">
              <div class="mt-2 bg-gray-900 border border-gray-800 rounded-xl shadow-2xl p-3 min-w-[160px] backdrop-blur-md">
                {link.sub.map(s => (
                  <a href={s.href} class="block px-4 py-2 text-sm rounded-lg hover:bg-neon-purple/20 hover:text-neon-pink transition-colors">
                    {s.label}
                  </a>
                ))}
              </div>
            </div>
          )}
        </li>
      ))}
    </ul>

    <div class="flex items-center gap-3">
      <button class="p-2 hover:text-neon-pink transition-colors" aria-label="Buscar">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
      </button>
      <button class="md:hidden p-2" aria-label="Menu">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
      </button>
    </div>
  </nav>

  <script>
    const header = document.getElementById('site-header');
    window.addEventListener('scroll', () => {
      if (window.scrollY > 50) {
        header.classList.add('shadow-lg', 'shadow-neon-purple/10');
        header.style.background = 'rgba(10,10,15,0.95)';
      } else {
        header.classList.remove('shadow-lg', 'shadow-neon-purple/10');
      }
    });
  </script>
</header>